{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "XinOne",
    "version": "0.1.0",
    "identifier": "io.xinone.launcher",
    "build": {
        "beforeDevCommand": "npm run vite-dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run vite-build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "XinOne",
                "width": 1280,
                "height": 720,
                "minWidth": 960,
                "minHeight": 540
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
